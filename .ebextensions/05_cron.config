# Schedules the pending-request digest emails (lib/tasks/notifications.rake) on
# the single web instance. Cron does not inherit EB environment properties, so
# each entry sources /opt/elasticbeanstalk/deployment/env (root-only readable,
# hence running as root) before invoking the task.
#
# NOTE: These entries run on EVERY instance. If this environment ever scales
# beyond one instance, add a leader-election guard or move the schedule to a
# worker-tier environment (cron.yaml) to avoid duplicate emails.
files:
  "/etc/cron.d/flextensions_digests":
    mode: "000644"
    owner: root
    group: root
    content: |
      SHELL=/bin/bash
      # Instance clock is UTC; 17:00 UTC = 9am PST / 10am PDT.
      # minute hour dom mon dow user command
      0 17 * * *   root  set -a; source /opt/elasticbeanstalk/deployment/env; set +a; cd /var/app/current && bundle exec rails 'notifications:send_pending_digests[daily]'  >> /var/log/pending_digests.log 2>&1
      0 17 * * FRI root  set -a; source /opt/elasticbeanstalk/deployment/env; set +a; cd /var/app/current && bundle exec rails 'notifications:send_pending_digests[weekly]' >> /var/log/pending_digests.log 2>&1

commands:
  remove_stale_cron_backup:
    command: "rm -f /etc/cron.d/flextensions_digests.bak"
