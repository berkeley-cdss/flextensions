<!-- <div class="d-flex flex-column flex-shrink-0 p-3 bg-body-tertiary sidebar-container">-->
<nav id="sidebar" class="bg-body-tertiary border-end" data-controller="sidebar" data-sidebar-target="sidebar" style="position: fixed; top: calc(56px); min-height: calc(100vh - 112px);">
	<!-- Mobile sidebar close button -->
		<button id="mobileSidebarClose" class="btn btn-light btn-sm d-md-none" type="button" data-action="click->sidebar#closeSidebar" data-sidebar-target="closeBtn" aria-label="Close sidebar" style="display:none; position:absolute; top:8px; right:8px; z-index:1050;">
			<i class="fa-solid fa-xmark"></i>
		</button>

	<ul class="nav nav-pills flex-column mt-3 mt-md-0">
		<li class="nav-item p-2 border-bottom">
		<%= link_to "/courses", class: "nav-link d-flex align-items-center" do %>
			<div class="sidebar-icon-container ms-3">
				<i class="fas fa-arrow-left fa-fw me-3"></i>
			</div>
			<span class="sidebar-text">Back to Courses</span>
		<% end %>
		</li>

		<%= sidebar_nav_item path: course_path(@course.id), icon: 'fas fa-tasks', nav: 'show', text: 'Assignments' %>

		<%= sidebar_nav_item path: course_requests_path(@course.id), icon: 'fas fa-clock', nav: 'requests' do %>
			Requests <span class="badge rounded-pill float-end text-bg-danger ms-2"><%= @pending_requests_count %></span>
		<% end %>

		<% if @role == 'instructor' %>
			<%= sidebar_nav_item path: enrollments_course_path(@course.id), icon: 'fas fa-users', nav: 'enrollments', text: 'Enrollments' %>

			<% settings_open = %w[course_details approvals emails form_settings].include?(current_nav_page) %>
			<li class="nav-item p-2">
				<a class="nav-link d-flex align-items-center link-body-emphasis<%= ' collapsed' unless settings_open %>"
					data-bs-toggle="collapse"
					href="#settingsSubmenu"
					role="button"
					aria-expanded="<%= settings_open %>"
					aria-controls="settingsSubmenu">
					<div class="sidebar-icon-container ms-3">
						<i class="fas fa-cog fa-fw me-3"></i>
					</div>
					<span class="nav-text ms-2">Course Settings</span>
					<i class="fas fa-chevron-down fa-xs ms-auto"></i>
				</a>
				<ul class="nav flex-column collapse <%= 'show' if settings_open %>" id="settingsSubmenu">
					<%= sidebar_nav_item path: edit_course_path(@course.id), icon: 'fas fa-circle-info', nav: 'course_details', text: 'Course Details' %>
					<%= sidebar_nav_item path: approvals_course_settings_path(@course.id), icon: 'fas fa-circle-check', nav: 'approvals', text: 'Automatic Approvals' %>
					<%= sidebar_nav_item path: emails_course_settings_path(@course.id), icon: 'fas fa-envelope', nav: 'emails', text: 'Email Templates' %>
					<%= sidebar_nav_item path: edit_course_form_setting_path(@course.id), icon: 'fas fa-file-alt', nav: 'form_settings', text: 'Request Form' %>
				</ul>
			</li>

			<%= sidebar_nav_item path: new_course_request_path(@course.id), icon: 'fas fa-user-plus', nav: 'form', text: 'Request for Student' %>
		<% end %>

		<% if @role == 'student' %>
			<%= sidebar_nav_item path: new_course_request_path(@course.id), icon: 'fas fa-file-pen', nav: 'form', text: 'Request Extension' %>
		<% end %>
	</ul>
</nav>
